NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_OAUTH_STATE_SECRET=
GOOGLE_API_KEY=

# IA — Ollama (local via Cloudflare Tunnel) ou Gemini (fallback)
# Se OLLAMA_HOST estiver definido, Ollama é usado. Senão, usa Gemini.
OLLAMA_HOST=          # ex: https://seu-tunel.trycloudflare.com
OLLAMA_MODEL=llama3.2 # modelo instalado no Ollama (llama3.2, mistral, phi3...)

# Gemini AI (fallback quando OLLAMA_HOST não estiver configurado)
GEMINI_API_KEY=
